+// This file provides a Node.js-compatible entry point
+// Metro bundler will resolve to src/index.ts instead for actual runtime
+
+const NativeModulesProxy = {};
+
+function requireOptionalNativeModule(moduleName) {
+  return NativeModulesProxy[moduleName] ?? null;
+}
+
+function requireNativeModule(moduleName) {
+  const module = requireOptionalNativeModule(moduleName);
+  if (!module) {
+    throw new Error(`Cannot find native module '${moduleName}'`);
+  }
+  return module;
+}
+
+class CodedError extends Error {
+  constructor(message, code) {
+    super(message);
+    this.code = code;
+    this.name = 'CodedError';
+  }
+}
+
+class UnavailabilityError extends Error {
+  constructor(moduleName, propertyName) {
+    super(`Property '${propertyName}' is not available on module '${moduleName}'`);
+    this.name = 'UnavailabilityError';
+  }
+}
+
+class EventEmitter {
+  constructor() {
+    this._listeners = {};
+  }
+  
+  addListener(event, listener) {
+    if (!this._listeners[event]) {
+      this._listeners[event] = [];
+    }
+    this._listeners[event].push(listener);
+    return { remove: () => this.removeListener(event, listener) };
+  }
+  
+  removeListener(event, listener) {
+    if (this._listeners[event]) {
+      this._listeners[event] = this._listeners[event].filter(l => l !== listener);
+    }
+  }
+  
+  emit(event, ...args) {
+    if (this._listeners[event]) {
+      this._listeners[event].forEach(listener => listener(...args));
+    }
+  }
+}
+
+module.exports = {
+  requireOptionalNativeModule,
+  requireNativeModule,
+  Platform: { OS: process.platform === 'darwin' ? 'ios' : process.platform === 'win32' ? 'windows' : 'android' },
+  CodedError,
+  UnavailabilityError,
+  EventEmitter,
+  NativeModulesProxy,
+  LegacyEventEmitter: EventEmitter,
+  NativeModule: class NativeModule {},
+  SharedObject: class SharedObject {},
+  SharedRef: class SharedRef {},
+  requireNativeViewManager: () => null,
+  uuid: () => require('crypto').randomUUID?.() || Math.random().toString(36).substring(2),
+};
